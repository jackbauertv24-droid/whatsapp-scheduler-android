<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.QueueFragment">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/queue_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:padding="16dp"/>

    <TextView
        android:id="@+id/emptyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/queue_empty"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="32dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/pendingHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/queue_pending"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/pending"
        android:padding="8dp"
        android:background="@color/gray_light"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pendingList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/sentHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/queue_sent"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/sent"
        android:padding="8dp"
        android:background="@color/gray_light"
        android:layout_marginTop="16dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/sentList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/failedHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/queue_failed"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/failed"
        android:padding="8dp"
        android:background="@color/gray_light"
        android:layout_marginTop="16dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/failedList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"/>

</LinearLayout>